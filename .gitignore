# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Environment variables
.env

# Datasets and heavy local files
data/*
!data/.gitkeep
!data/README.md

# Model checkpoints can be large. Keep .gitkeep only by default.
models/*.pth
models/*.pt
models/*.ckpt
!models/.gitkeep

# Outputs: keep folder placeholders, but ignore generated heavy assets by default.
outputs/videos/*
outputs/reports/*
outputs/charts/*
outputs/screenshots/*
!outputs/.gitkeep
!outputs/videos/.gitkeep
!outputs/reports/.gitkeep
!outputs/charts/.gitkeep
!outputs/screenshots/.gitkeep

# Jupyter checkpoints
.ipynb_checkpoints/

# Temporary generated reports
outputs/reports/frame_metrics.csv
outputs/reports/presentation_report.md
outputs/reports/summary_report.json


# Temporary generated Phase 3 charts at root level
outputs/charts/phase3_*.png

# Keep curated assets
!outputs/charts/phase3/
!outputs/charts/phase3/*.png
!outputs/reports/phase3/
!outputs/reports/phase3/*.md
!outputs/reports/phase3/*.json
!outputs/screenshots/
!outputs/screenshots/**/*.png

# Videos: ignore by default
outputs/videos/*
!outputs/videos/.gitkeep


# PresentSense app-generated temporary outputs
outputs/app/uploads/*
outputs/app/videos/*
outputs/app/reports/*
outputs/app/charts/*
!outputs/app/uploads/.gitkeep
!outputs/app/videos/.gitkeep
!outputs/app/reports/.gitkeep
!outputs/app/charts/.gitkeep


