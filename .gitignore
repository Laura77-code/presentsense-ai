# Python cache / tooling
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Environment variables
.env

# Datasets and local samples
data/*
!data/.gitkeep
!data/README.md

# Model checkpoints
models/*
!models/.gitkeep


# Outputs: ignore generated files by default

# Videos are usually large
outputs/videos/*
!outputs/videos/.gitkeep

# Temporary root-level reports generated by analyze_video.py
outputs/reports/*
!outputs/reports/.gitkeep

# Temporary root-level charts generated by analyze_video.py
outputs/charts/*
!outputs/charts/.gitkeep

# Streamlit app temporary outputs
outputs/app/uploads/*
outputs/app/videos/*
outputs/app/reports/*
outputs/app/charts/*
!outputs/app/
!outputs/app/uploads/
!outputs/app/videos/
!outputs/app/reports/
!outputs/app/charts/
!outputs/app/uploads/.gitkeep
!outputs/app/videos/.gitkeep
!outputs/app/reports/.gitkeep
!outputs/app/charts/.gitkeep


# Keep curated README/demo assets

# Keep outputs folder placeholders
!outputs/
!outputs/.gitkeep

# Keep curated charts for README
!outputs/charts/
!outputs/charts/exp03_resnet18_finetune_confusion_matrix.png
!outputs/charts/exp03_resnet18_finetune_training_curves.png
!outputs/charts/exp04_mobilenet_finetune_confusion_matrix.png
!outputs/charts/exp04_mobilenet_finetune_training_curves.png
!outputs/charts/phase3/
!outputs/charts/phase3/**
!outputs/charts/phase3/*.png

# Keep curated reports for README
!outputs/reports/
!outputs/reports/experiments.csv
!outputs/reports/phase3/
!outputs/reports/phase3/**
!outputs/reports/phase3/*.md
!outputs/reports/phase3/*.json
!outputs/reports/phase3/*.csv

# Keep curated screenshots for README/demo
!outputs/screenshots/
!outputs/screenshots/**/
!outputs/screenshots/**/*.png
!outputs/screenshots/**/.gitkeep